# .envrc
# Automatically activates the Nix development environment via nix-direnv
# when entering this directory. Requires direnv and nix-direnv to be configured
# in Home Manager (use_nix is provided by nix-direnv).
#
# Run `direnv allow` once after cloning to enable.

use flake

# LocalStack dummy credentials — required by AWS SDK and CLI
export AWS_ACCESS_KEY_ID=test
export AWS_SECRET_ACCESS_KEY=test
export AWS_DEFAULT_REGION=eu-west-1

# Redirect all AWS CLI and SDK calls to LocalStack
export AWS_ENDPOINT_URL=http://localhost:4566
